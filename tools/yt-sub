#!/bin/bash
# YouTube 字幕產生器 - 啟動腳本
# 自動使用 venv 環境執行 Whisper 字幕產生器
#
# 使用方式:
#   ./yt-sub <YouTube_URL> [options]
#   ./yt-sub https://www.youtube.com/watch?v=xxx --model medium --lang zh
#
# 快速捷徑（加入 alias 到 ~/.zshrc）:
#   alias yt-sub="/path/to/AI_NOTE/tools/yt-sub"

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
VENV_DIR="$SCRIPT_DIR/.venv"

# 檢查 venv 是否存在
if [ ! -d "$VENV_DIR" ]; then
    echo "⚠ 找不到虛擬環境，正在建立..."
    python3 -m venv "$VENV_DIR"
    source "$VENV_DIR/bin/activate"
    pip install openai-whisper yt-dlp
else
    source "$VENV_DIR/bin/activate"
fi

# 執行主腳本
python3 "$SCRIPT_DIR/yt-whisper-sub.py" "$@"